# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/quarry

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── API ───────────────────────────────────────────────────────────────────────
PORT=3000

# ── LLM provider (/extract and monitor AI judge) ──────────────────────────────
# Provider: openai (default) or anthropic
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o
# Override base URL for Ollama, Groq, Together, LM Studio, etc.
# LLM_BASE_URL=http://localhost:11434/v1

# ── Crawler settings ──────────────────────────────────────────────────────────
# Minimum delay between requests to the same domain (ms)
POLITENESS_MS=300
# How many days to keep structured logs in Postgres
LOG_RETENTION_DAYS=30
